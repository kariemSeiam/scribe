# ── SCRIBE environment variables ──────────────────────────────────────────────
#
# This file is committed. Copy to .env.local for local overrides.
# In production (GitHub Pages), set these in:
#   Repository → Settings → Secrets and variables → Variables
#
# ─────────────────────────────────────────────────────────────────────────────

# Base path for GitHub Pages deployment.
# Must match your repository name exactly, including the leading slash.
# Example: /scribe
# Leave empty when using a custom domain (apex or subdomain).
NEXT_PUBLIC_BASE_PATH=
